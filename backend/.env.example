# Universal Story Board - 环境变量配置示例
# 复制此文件为 .env 并填写实际配置值

# 应用配置
APP_NAME="Universal Story Board"
APP_VERSION="1.0.0"
DEBUG=True

# 数据库配置（默认 SQLite）
DATABASE_TYPE=sqlite
DATABASE_URL=sqlite:///./usb.db

# LLM 配置（GLM-4）
GLM_API_KEY=your_glm_api_key_here
GLM_MODEL=glm-4-long

# 文生图配置（Stable Diffusion - 可选）
SD_API_URL=your_sd_api_url_here
SD_API_KEY=your_sd_api_key_here

# 文生视频配置（Sora2 - 可选）
SORA_API_URL=your_sora_api_url_here
SORA_API_KEY=your_sora_api_key_here

# 缓存配置（默认内存缓存）
CACHE_TYPE=memory
# CACHE_TYPE=redis
# REDIS_URL=redis://localhost:6379/0

# 速率限制
RATE_LIMIT_ENABLED=True
RATE_LIMIT_TIMES=100
RATE_LIMIT_SECONDS=60

# CORS 配置
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# 日志配置
LOG_LEVEL=INFO

# 加密密钥（用于 API Key 加密存储，首次运行时会自动生成）
# ENCRYPTION_KEY=your_encryption_key_here
